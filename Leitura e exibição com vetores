#include <stdio.h>

int main()
{
	int numeros [15];
	int i = 0;
	
	for(i = 0; i<15; i++){
		
		printf("Informe um numero: \n");
		scanf("%d", &numeros[i]);
		
	}
	
	for (i=0; i<15; i++){
		
		if(numeros[i]%2 == 0)	printf("V[%d] - %d - Par\n", i, numeros[i]);
		else 	printf("V[%d] - %d - Impar\n", i, numeros[i]);
	}
	
	
	
	return 0;
}
